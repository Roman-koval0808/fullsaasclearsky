// -----------------------------------------------------------------------------
// New model: Outcome
// Section 6 writes one row per eligible execution record.
// -----------------------------------------------------------------------------

model Outcome {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outcome_id              String   @unique                // out_<generated>
  event_id                String                          // → events.event_id (TEXT)
  decision_id             String                          // → orchestrator_decisions.decision_id
  action_queue_id         String                          // → action_queue.action_queue_id
  execution_id            String                          // → action_executions.action_execution_id
  action_id               String                          // e.g. ACT-REV-001
  outcome_type            String
  // draft_created | approved | edited_before_approval | posted |
  // sent | assigned | completed | rejected | failed |
  // no_action_taken | blocked_preserved
  outcome_status          String
  // completed | waiting_for_approval | waiting | blocked | failed
  time_to_response_hours  Float?
  approval_wait_hours     Float?
  human_edited            Boolean  @default(false)
  posted_externally       Boolean  @default(false)        // ALWAYS false at Section 6 insert
  do_not_count_as_success Boolean  @default(false)        // true for blocked/failed
  details                 Json?
  created_at              DateTime @default(now()) @db.Timestamptz(6)
  updated_at              DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  event                   Event    @relation(fields: [event_id], references: [event_id], onDelete: Cascade)

  @@map("outcomes")
}


// -----------------------------------------------------------------------------
// New model: BlockedOutcomeContext
// Audit-only records for blocked actions (ACT-REV-002 etc.)
// No corresponding outcomes row — these were never executed.
// -----------------------------------------------------------------------------

model BlockedOutcomeContext {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blocked_context_id        String   @unique               // blocked_ctx_<generated>
  event_id                  String
  decision_id               String
  action_id                 String                         // e.g. ACT-REV-002
  action_name               String?
  blocked_reason            String?
  outcome_type              String   @default("blocked_preserved")
  outcome_status            String   @default("blocked")
  posted_to_google          Boolean  @default(false)
  external_action_completed Boolean  @default(false)
  do_not_count_as_success   Boolean  @default(true)
  created_at                DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  event                     Event    @relation(fields: [event_id], references: [event_id], onDelete: Cascade)

  @@map("blocked_outcome_context")
}


